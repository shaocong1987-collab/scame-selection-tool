# ChromaDB 配置
CHROMA_SERVER_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=scame_knowledge_dev

# 嵌入模型配置
# 开发环境使用本地模型
EMBEDDING_MODEL=local
# 生产环境使用OpenAI
# EMBEDDING_MODEL=openai
# OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek 需求解析代理配置
# 真实 key 请写入 .env.local，不要提交到 git
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 本地嵌入模型配置
LOCAL_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# 文档处理配置
MAX_DOCUMENT_SIZE_MB=10
SUPPORTED_FILE_TYPES=pdf,docx,doc,txt,md

# 应用配置
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# 数据目录
DATA_DIR=./data
KNOWLEDGE_SOURCES_DIR=./data/knowledge-sources
PROCESSED_CHUNKS_DIR=./data/processed-chunks
VECTOR_INDEX_DIR=./data/vector-index

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
MAX_CACHE_SIZE_MB=100

# 性能配置
MAX_CONCURRENT_PROCESSES=4
BATCH_SIZE_DOCUMENTS=10
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# 开发模式快捷配置
# 设置DEV_MODE=true可使用内存存储替代ChromaDB
DEV_MODE=true
USE_MEMORY_STORAGE=true
